rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow uploads to /uploads folder
    match /uploads/{fileName} {
      // Allow anyone to upload images (for review submissions)
      allow write: if request.resource.size < 10 * 1024 * 1024  // Max 10MB
                   && request.resource.contentType.matches('image/.*');

      // Allow anyone to read uploaded images
      allow read: if true;
    }

    // Blog assets (cover images + inline content images).
    // Public read so the blog can render images for any visitor.
    // Write is restricted to the blog owner — the editor uses the
    // isolated `blog` Firebase app (`blogAuth` / `blogStorage`), so
    // request.auth.token.email comes from that session, not the
    // store/admin dashboards.
    match /blog/{path=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'abuyzzn@yahoo.com'
                   && request.resource.size < 5 * 1024 * 1024  // Max 5MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
